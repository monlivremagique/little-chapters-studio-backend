{% extends 'Admin/BookCreation/base.html.twig' %}

{% block title %}Création de livres{% endblock %}

{% block content %}
<div class="page-header" data-sticky-header>
    <div class="container-xl">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('sylius_admin_dashboard') }}">Tableau de bord</a></li>
            <li class="breadcrumb-item active">Création de livres</li>
        </ol>
        <div class="row mt-3 row-gap-2">
            <div class="col-12 col-md">
                <div class="d-flex gap-3 align-items-center">
                    <div>{{ ux_icon('tabler:book', {'class': 'icon icon-md text-primary'}) }}</div>
                    <div class="d-flex flex-column gap-2">
                        <h1 class="page-title">Création de livres</h1>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-auto ms-auto d-print-none">
                <div class="btn-list">
                    <a href="{{ path('app_admin_book_creation_new') }}" class="btn btn-primary">
                        {{ ux_icon('tabler:plus') }}
                        Créer un nouveau livre
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="page-body">
    <div class="container-xl">
        <div class="card">
            <div class="table-responsive">
                <table class="table card-table table-vcenter datatable">
                    <thead>
                        <tr>
                            <th>Titre</th>
                            <th>Slug</th>
                            <th>Statut</th>
                            <th>Progression</th>
                            <th>Créé le</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for project in projects %}
                        <tr>
                            <td class="fw-medium">{{ project.title }}</td>
                            <td><code>{{ project.slug }}</code></td>
                            <td>
                                {% set badges = {
                                    'draft': 'bg-secondary',
                                    'running': 'bg-primary',
                                    'validation': 'bg-success',
                                    'published': 'bg-teal',
                                    'failed': 'bg-danger',
                                } %}
                                <span class="badge {{ badges[project.status]|default('bg-secondary') }}">{{ project.status|capitalize }}</span>
                            </td>
                            <td>
                                <div class="progress" style="height:8px;max-width:150px">
                                    <div class="progress-bar" style="width:{{ project.progressPct }}%"></div>
                                </div>
                            </td>
                            <td>{{ project.createdAt|date('d/m/Y H:i') }}</td>
                            <td class="text-end">
                                <a href="{{ path('app_admin_book_creation_show', {'id': project.id}) }}" class="btn btn-icon" data-bs-toggle="tooltip" title="Voir">
                                    {{ ux_icon('tabler:eye') }}
                                </a>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="6">
                                <div class="empty">
                                    <div class="empty-img">{{ ux_icon('tabler:book-off', {'class': 'icon icon-xl'}) }}</div>
                                    <p class="empty-title">Aucun projet de création</p>
                                    <p class="empty-subtitle text-muted">Créez votre premier livre personnalisé.</p>
                                    <div class="empty-action">
                                        <a href="{{ path('app_admin_book_creation_new') }}" class="btn btn-primary">
                                            {{ ux_icon('tabler:plus') }} Créer un nouveau livre
                                        </a>
                                    </div>
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
