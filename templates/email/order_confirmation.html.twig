{% extends 'email/base.html.twig' %}

{% block subject %}
    {% if localeCode == 'fr' %}
        Confirmation de votre commande {{ orderNumber }} &mdash; Mon Livre Magique
    {% elseif localeCode == 'nl' %}
        Bevestiging van uw bestelling {{ orderNumber }} &mdash; Mijn Magische Boek
    {% else %}
        Order {{ orderNumber }} confirmed &mdash; My Magic Book
    {% endif %}
{% endblock %}

{% block content %}
    {% set locale = localeCode|default('fr') %}

    <div style="text-align: center; margin-bottom: 28px;">
        <div style="font-size: 42px; margin-bottom: 8px;">&#x1F4D6;</div>
        <h1 style="font-size: 24px; color: #2d1b69; margin: 0 0 6px;">
            {% if locale == 'fr' %}Merci pour votre commande !{% elseif locale == 'nl' %}Dank u voor uw bestelling!{% else %}Thank you for your order!{% endif %}
        </h1>
        <p style="color: #666; margin: 0; font-size: 15px;">
            {% if locale == 'fr' %}Votre livre personnalisé est en cours de préparation{% elseif locale == 'nl' %}Uw gepersonaliseerde boek wordt voorbereid{% else %}Your personalized book is being prepared{% endif %}
        </p>
    </div>

    <div style="background: #f8f6ff; border-radius: 8px; padding: 20px 24px; margin-bottom: 24px; border: 1px solid #e8e0f0;">
        <table style="width: 100%; border-collapse: collapse;">
            <tr>
                <td style="padding: 6px 12px; color: #888; font-size: 13px; white-space: nowrap;">
                    {% if locale == 'fr' %}Commande{% elseif locale == 'nl' %}Bestelling{% else %}Order{% endif %}
                </td>
                <td style="padding: 6px 12px; font-weight: 700; color: #2d1b69; text-align: right;">{{ orderNumber }}</td>
            </tr>
            <tr>
                <td style="padding: 6px 12px; color: #888; font-size: 13px; white-space: nowrap;">
                    {% if locale == 'fr' %}Enfant{% elseif locale == 'nl' %}Kind{% else %}Child{% endif %}
                </td>
                <td style="padding: 6px 12px; text-align: right;">{{ childName }}</td>
            </tr>
            <tr>
                <td style="padding: 6px 12px; color: #888; font-size: 13px; white-space: nowrap;">
                    {% if locale == 'fr' %}Livre{% elseif locale == 'nl' %}Boek{% else %}Book{% endif %}
                </td>
                <td style="padding: 6px 12px; text-align: right;"><strong>{{ bookTitle }}</strong></td>
            </tr>
            <tr>
                <td style="padding: 6px 12px; color: #888; font-size: 13px; white-space: nowrap;">
                    {% if locale == 'fr' %}Total{% elseif locale == 'nl' %}Totaal{% else %}Total{% endif %}
                </td>
                <td style="padding: 6px 12px; text-align: right; font-size: 18px; font-weight: 700; color: #2d1b69;">{{ orderTotal }}</td>
            </tr>
            <tr>
                <td style="padding: 6px 12px; color: #888; font-size: 13px; white-space: nowrap;">
                    {% if locale == 'fr' %}Statut{% elseif locale == 'nl' %}Status{% else %}Status{% endif %}
                </td>
                <td style="padding: 6px 12px; text-align: right;">
                    <span style="display: inline-block; background: #e8f5e9; color: #2e7d32; padding: 2px 12px; border-radius: 12px; font-size: 13px; font-weight: 600;">
                        {{ status }}
                    </span>
                </td>
            </tr>
        </table>
    </div>

    <div style="background: #fff8e1; border-radius: 8px; padding: 16px 20px; margin-bottom: 24px; border: 1px solid #ffe082;">
        <p style="margin: 0 0 4px; font-size: 14px; color: #e65100;">
            <strong>&#x1F31F;</strong>
            {% if locale == 'fr' %}
                Nous préparons votre livre avec amour. Vous recevrez un email dès que la production commencera.
            {% elseif locale == 'nl' %}
                We maken uw boek met liefde klaar. U ontvangt een e-mail zodra de productie begint.
            {% else %}
                We are preparing your book with love. You will receive an email as soon as production starts.
            {% endif %}
        </p>
    </div>

    <div style="text-align: center; margin-top: 24px;">
        <a href="https://www.monlivremagique.be{% if locale == 'fr' %}/fr{% elseif locale == 'nl' %}/nl{% else %}/en{% endif %}/compte/commandes/{{ orderNumber }}"
           style="display: inline-block; background: #2d1b69; color: #ffffff; text-decoration: none; padding: 14px 36px; border-radius: 8px; font-weight: 600; font-size: 15px;">
            {% if locale == 'fr' %}Suivre ma commande{% elseif locale == 'nl' %}Mijn bestelling volgen{% else %}Track my order{% endif %}
        </a>
    </div>

    <div style="text-align: center; margin-top: 20px; font-size: 13px; color: #999; border-top: 1px solid #eee; padding-top: 20px;">
        <p style="margin: 0;">
            {% if locale == 'fr' %}
                Une question ? Contactez-nous à <a href="mailto:bonjour@monlivremagique.be" style="color: #2d1b69;">bonjour@monlivremagique.be</a>
            {% elseif locale == 'nl' %}
                Een vraag? Neem contact op via <a href="mailto:bonjour@monlivremagique.be" style="color: #2d1b69;">bonjour@monlivremagique.be</a>
            {% else %}
                Questions? Contact us at <a href="mailto:bonjour@monlivremagique.be" style="color: #2d1b69;">bonjour@monlivremagique.be</a>
            {% endif %}
        </p>
    </div>
{% endblock %}
