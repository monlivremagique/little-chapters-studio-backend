APP_ENV=prod
APP_DEBUG=0
APP_RUNTIME_MODE=web=1
APP_SECRET=__REQUIRED_APP_SECRET__
APP_SHARE_DIR=var/share

DATABASE_URL=__REQUIRED_POSTGRES_DATABASE_URL__
MESSENGER_TRANSPORT_DSN=doctrine://default
SYLIUS_MESSENGER_TRANSPORT_MAIN_DSN=doctrine://default
SYLIUS_MESSENGER_TRANSPORT_MAIN_FAILED_DSN=doctrine://default?queue_name=main_failed
SYLIUS_MESSENGER_TRANSPORT_CATALOG_PROMOTION_REMOVAL_DSN=doctrine://default?queue_name=catalog_promotion_removal
SYLIUS_MESSENGER_TRANSPORT_CATALOG_PROMOTION_REMOVAL_FAILED_DSN=doctrine://default?queue_name=catalog_promotion_removal_failed
SYLIUS_MESSENGER_TRANSPORT_PAYMENT_REQUEST_DSN=sync://
SYLIUS_MESSENGER_TRANSPORT_PAYMENT_REQUEST_FAILED_DSN=sync://

MAILER_DSN=__REQUIRED_POSTMARK_OR_BREVO_SMTP_DSN__
ALERT_EMAIL_FROM=__REQUIRED_TRANSACTIONAL_FROM_EMAIL__
ALERT_EMAIL_TO=__REQUIRED_OPERATIONS_ALERT_EMAIL__

DEFAULT_URI=https://backend.monlivremagique.be
FRONTEND_BASE_URL=https://monlivremagique.be
PHP_DATE_TIMEZONE=Europe/Brussels

JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=__REQUIRED_GENERATE_WITH_openssl_rand_base64_32__

STRIPE_SECRET_KEY=__REQUIRED_STRIPE_SECRET_KEY__
STRIPE_WEBHOOK_SECRET=__REQUIRED_STRIPE_WEBHOOK_SECRET__

REPLICATE_API_BASE_URI=https://api.replicate.com/v1
REPLICATE_API_TOKEN=__REQUIRED_REPLICATE_API_TOKEN__
REPLICATE_MODEL=black-forest-labs/flux-2-pro
REPLICATE_MAX_RETRIES=2
PERSONALIZATION_GENERATION_PAGE_LIMIT=4

GELATO_API_BASE_URI=https://order.gelatoapis.com
GELATO_API_KEY=__REQUIRED_GELATO_API_KEY__
GELATO_PRODUCT_UID=__REQUIRED_GELATO_PRODUCT_UID__
GELATO_SHIPMENT_METHOD_UID=standard
GELATO_WEBHOOK_SECRET=__REQUIRED_GELATO_WEBHOOK_SECRET__
GELATO_PUBLIC_BASE_URL=https://backend.monlivremagique.be

SUPPORT_OPERATIONS_TOKEN=__REQUIRED_SUPPORT_OPERATIONS_TOKEN__
SYLIUS_PAYMENT_ENCRYPTION_KEY_PATH=%kernel.project_dir%/config/encryption/prod.key

# Railway persistent volume is attached at /srv/sylius/var/storage.
# This env var must be set to "true" in the Railway dashboard (volume is now mounted).
PDF_STORAGE_PERSISTENT=__REQUIRED_SET_TO_true_VOLUME_IS_MOUNTED_AT_/srv/sylius/var/storage__

# RGPD — child photo encryption at rest
# Generate with: php -r "echo bin2hex(sodium_crypto_aead_aes256gcm_keygen());"
# WARNING: Loss of this key makes all encrypted photos permanently unrecoverable.
PHOTO_ENCRYPTION_KEY=__REQUIRED_GENERATE_64_HEX_CHARS_PREVIOUS_COMMAND__
PHOTO_STORAGE_MAX_RETENTION_DAYS=30

# Rate limiting — protect against abuse, burn, brute force
RL_GENERATION_LIMIT=3
RL_GENERATION_INTERVAL=60
RL_UPLOAD_LIMIT=5
RL_UPLOAD_INTERVAL=60
RL_MUTATION_LIMIT=20
RL_MUTATION_INTERVAL=60
RL_AUTH_LIMIT=5
RL_AUTH_INTERVAL=60
RL_CHECKOUT_LIMIT=5
RL_CHECKOUT_INTERVAL=60
RL_READ_LIMIT=100
RL_READ_INTERVAL=60
RL_WEBHOOK_LIMIT=30
RL_WEBHOOK_INTERVAL=60
RL_SUPPORT_LIMIT=20
RL_SUPPORT_INTERVAL=60
RL_GLOBAL_LIMIT=200
RL_GLOBAL_INTERVAL=60
